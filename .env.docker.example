# Copy this file to .env.docker before running `docker compose up`.
# Only for scripts/seed-admin-users.mjs, run inside the `web` container via the
# `predev` npm script. SUPABASE_URL itself is set in docker-compose.yml (points
# at host.docker.internal, not 127.0.0.1, since this runs inside a container) -
# don't duplicate it here.
#
# Never commit real values - .env.docker is git-ignored.

SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key_from_supabase_start

DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_Admin1!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=change_me_User1!
DEFAULT_USER_USERNAME=user
