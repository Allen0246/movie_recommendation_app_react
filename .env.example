# Copy this file to .env.local (frontend build-time vars) and set the
# remaining ones in your shell / CI secrets before running the one-time scripts
# below. Never commit real values — .env.local and this repo's actual
# .env are both git-ignored.

# --- Frontend build-time vars (.env.local) ---
# Local dev defaults shown; `supabase start` prints the real local values.
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=replace_with_anon_key_from_supabase_start_or_dashboard

# --- Used by scripts/seed-admin-users.mjs and scripts/bootstrap-tmdb-sync.mjs ---
# Never expose the service role key to the frontend — export these in your shell
# (not .env.local) before running `npm run dev` or the scripts directly.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key_from_supabase_start_or_dashboard

# --- scripts/seed-admin-users.mjs: default admin/test account bootstrap ---
# Idempotent (skips accounts that already exist), so it's safe to leave these set —
# `npm run dev` re-runs it on every startup via the `predev` script. If unset,
# seeding is silently skipped and dev still starts normally.
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change_me_Admin1!
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_USER_EMAIL=user@example.com
DEFAULT_USER_PASSWORD=change_me_User1!
DEFAULT_USER_USERNAME=user

# --- scripts/bootstrap-tmdb-sync.mjs: one-time historical backfill only ---
# Not read by the routine sync path (cron + the "Update" button always use today).
PRIMARY_RELEASE_DATE_GTE=2024-02-27

# --- Supabase secrets (set via `supabase secrets set`, NOT read from this file) ---
# TMDB_HOSTNAME=api.themoviedb.org
# TMDB_TOKEN=your_tmdb_api_key_or_read_access_token
