# Dev-mode image: runs the Vite dev server with hot reload, source mounted as a
# volume by docker-compose.yml. Not used for production builds (see README/`build`
# script for the tsc + `vite build` static-asset path nginx would serve in prod).
FROM node:22-alpine
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm install

COPY . .

EXPOSE 5173
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
